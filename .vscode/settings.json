    "^~/.*\\/_lib\\/(?!index(?:\\.tsx?)?$).+",
    "^\\.\\./.*\\/_lib\\/(?!index(?:\\.tsx?)?$).+",
    "^\\.\\./_lib\\/(?!index(?:\\.tsx?)?$).+"
  ],
