{
  "name": "blaze-build",
  "version": "0.1.0",
  "private": true,
  "sideEffects": [
    "*.css"
  ],
  "type": "module",
  "scripts": {
    "build": "next build",
    "check": "next lint && tsc --noEmit && pnpm check:exports",
    "check:exports": "node ./scripts/check-dangling-exports.mjs",
    "db:generate": "prisma migrate dev",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:cleanup:orphan-files": "node --env-file=.env ./scripts/cleanup-orphan-files.mjs",
    "dev": "next dev --turbo",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "postinstall": "prisma generate",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "preview": "next build && next start",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "create-user": "node --env-file=.env ./scripts/create-user.cjs"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.2",
    "@base-ui/react": "^1.2.0",
    "@prisma/client": "^6.6.0",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@t3-oss/env-nextjs": "^0.12.0",
    "@tanstack/react-form": "^1.29.0",
    "@tanstack/react-query": "^5.69.0",
    "@tanstack/react-table": "^8.21.3",
    "@tiptap/extension-bubble-menu": "^3.22.5",
    "@tiptap/extension-code-block-lowlight": "^3.22.5",
    "@tiptap/extension-color": "^3.22.5",
    "@tiptap/extension-heading": "^3.22.5",
    "@tiptap/extension-horizontal-rule": "^3.22.5",
    "@tiptap/extension-image": "^3.22.5",
    "@tiptap/extension-link": "^3.22.5",
    "@tiptap/extension-placeholder": "^3.22.5",
    "@tiptap/extension-text-style": "^3.22.5",
    "@tiptap/extension-typography": "^3.22.5",
    "@tiptap/extension-underline": "^3.22.5",
    "@tiptap/pm": "^3.22.5",
    "@tiptap/react": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "axios": "^1.17.0",
    "bcrypt": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "i18next": "^26.0.6",
    "image-size": "^2.0.2",
    "input-otp": "^1.4.2",
    "lowlight": "^3.3.0",
    "lucide-react": "^0.577.0",
    "next": "^15.2.3",
    "next-auth": "5.0.0-beta.25",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.0.0",
    "react-medium-image-zoom": "^5.4.3",
    "react-resizable-panels": "^4.7.2",
    "react-slick": "^0.31.0",
    "recharts": "2.15.4",
    "server-only": "^0.0.1",
    "shadcn": "^4.0.2",
    "slick-carousel": "^1.8.1",
    "socks-proxy-agent": "^10.0.0",
    "sonner": "^2.0.7",
    "superjson": "^2.2.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "typograf": "^6.8.2",
    "vaul": "^1.1.2",
    "zod": "^3.24.2",
    "zod-i18n-map": "^2.27.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.0.15",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^20.14.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-slick": "^0.23.13",
    "eslint": "^9.23.0",
    "eslint-config-next": "^15.2.3",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "knip": "^6.16.1",
    "postcss": "^8.5.3",
    "postcss-import": "^16.1.1",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "prisma": "^6.6.0",
    "tailwindcss": "^4.0.15",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.27.0"
  },
  "ct3aMetadata": {
    "initVersion": "7.40.0"
  }
}
