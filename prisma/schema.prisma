// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  // NOTE: When using mysql or sqlserver, uncomment the @db.Text annotations in model Account below
  // Further reading:
  // https://next-auth.js.org/adapters/prisma#create-the-prisma-schema
  // https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#string
  url      = env("DATABASE_URL")
}

// Necessary for Next auth
model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String? // @db.Text
  access_token             String? // @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String? // @db.Text
  session_state            String?
  user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  refresh_token_expires_in Int?

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model File {
  id  String  @id
  alt String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories              Category[]
  projectMainImages       Project[] @relation("ProjectMainImage")
  projectAdditionalImages Project[] @relation("ProjectAdditionalImages")
  leadAttachments         Lead[]    @relation("LeadAttachments")
}

/// Режим шапки публичной страницы категории.
enum CategoryHeaderMode {
  /// Крупный баннер с фоном (как исторически у всех категорий).
  HERO
  /// Компактная шапка: хлебные крошки + заголовок + короткое описание.
  COMPACT
}

/// Как выводятся подкатегории на странице и участвуют ли они в сайдбаре.
enum CategoryChildrenMode {
  /// Сетка плиток с фото (как исторически).
  TILES
  /// Дерево в левом сайдбаре, контент справа (каталог как на evraz.pro).
  SIDEBAR
  /// Карточки товаров в потоке контента; такие дети не попадают в сайдбар.
  CARDS
}

model Category {
  id               String  @id
  title            String
  /// Подзаголовок на лендинге категории — под основным названием в шапке.
  landingTitle     String?
  shortDescription String?
  /// Скрыта с сайта (карточки и лендинг); в админке остаётся видимой.
  isHidden         Boolean @default(false)

  headerMode   CategoryHeaderMode   @default(HERO)
  childrenMode CategoryChildrenMode @default(TILES)
  /// Заголовок каталожной зоны при HERO + SIDEBAR; null → «Каталог».
  catalogTitle String?
  /// Порядок среди детей одного родителя: меньше — раньше; при равенстве — по title.
  sortOrder    Int                  @default(0)
  /// Секции контента страницы; jsonb-массив, схема — src/sections/schema.ts.
  sections     Json                 @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  imageId  String?
  image    File?     @relation(fields: [imageId], references: [id])
  projects Project[]

  subcategories    Category[] @relation("CategoryHierarchy")
  parentCategories Category[] @relation("CategoryHierarchy")
  videos           Video[]
  leads            Lead[]
}

model Project {
  id               String  @id
  title            String
  shortDescription String?
  /// Календарная дата без времени и TZ, формат YYYY-MM-DD.
  dateCompleted    String
  price            String?
  timeToComplete   String?
  /// Задача — простой HTML (richtext).
  task             String?
  /// Процесс работы — простой HTML (richtext).
  workProgress     String?
  /// Результат — простой HTML (richtext).
  result           String?
  /// Скрыт с сайта; в админке остаётся видимым.
  isHidden         Boolean @default(false)

  mainImageId String?
  mainImage   File?   @relation("ProjectMainImage", fields: [mainImageId], references: [id])

  additionalImages File[] @relation("ProjectAdditionalImages")

  categories Category[]
  leads      Lead[]
}

model Lead {
  id        String   @id @default(cuid())
  title     String
  email     String
  message   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])

  files File[] @relation("LeadAttachments")
}

model Video {
  id          String  @id
  title       String
  description String?
  url         String

  categories Category[]
}

/// Singleton: одна строка с id = "default".
model SiteSettings {
  id String @id @default("default")

  /// Id работ, закреплённых на главной, в порядке отображения.
  homepagePinnedProjectIds String[] @default([])
}
